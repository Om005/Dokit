{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "moduleResolution": "node",
        "rootDir": "./src",
        "outDir": "./dist",
        "baseUrl": "./src",
        "paths": {
            "@config/*": ["config/*"],
            "@modules/*": ["modules/*"],
            "@generated/*": ["generated/*"],
            "@db/*": ["db/*"],
            "@utils/*": ["utils/*"],
            "@middlewares/*": ["middlewares/*"],
            "@sockets/*": ["sockets/*"]
        },

        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,

        "types": ["node"]
    },
    "include": ["src"]
}
