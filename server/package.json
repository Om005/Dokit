        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^25.1.0",
        "@types/ua-parser-js": "^0.7.39",
        "cross-env": "^10.1.0",
