{
    "name": "server",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "scripts": {
        "build": "tsc && tsc-alias",
        "dev": "cross-env NODE_ENV=development tsx watch --clear-screen=false --watch src src/index.ts",
        "start": "cross-env NODE_ENV=production node dist/index.js",
        "prisma:generate": "cross-env NODE_ENV=development prisma generate",
        "prisma:migrate": "cross-env NODE_ENV=development prisma migrate dev",
        "script:geoip:dev": "cross-env NODE_ENV=development bash ./scripts/update.sh",
        "script:geoip:prod": "cross-env NODE_ENV=production bash ./scripts/update.sh",
        "script:templates:dev": "cross-env NODE_ENV=development tsx ./scripts/uploadBaseTemplates.ts",
        "script:templates:prod": "cross-env NODE_ENV=production tsx ./scripts/uploadBaseTemplates.ts",
        "script:images": "bash ./scripts/make_images.sh",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "packageManager": "pnpm@10.25.0",
    "dependencies": {
        "@aws-sdk/client-s3": "^3.991.0",
        "@prisma/client": "^6.19.2",
        "@types/dockerode": "^4.0.1",
        "argon2": "^0.44.0",
        "axios": "^1.13.4",
        "bullmq": "^5.67.2",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "crypto": "^1.0.1",
        "dockerode": "^4.0.9",
        "dotenv": "^17.2.3",
        "express": "^5.2.1",
        "http-status-codes": "^2.3.0",
        "jsonwebtoken": "^9.0.3",
        "maxmind": "^5.0.3",
        "node-cron": "^4.2.1",
        "node-fetch": "^3.3.2",
        "pino": "^10.3.0",
        "pino-http": "^11.0.0",
        "redis": "^5.10.0",
        "ua-parser-js": "^2.0.8",
        "zod": "^4.3.6"
    },
    "devDependencies": {
